# Postgres connection string (Neon). Required — leads, portal messages,
# appointments, and paid invoice status are all stored here. Provisioned
# automatically for Vercel deployments via the Neon integration; for local
# dev, run `vercel env pull .env.local` to fetch it.
DATABASE_URL=

# Contact form submissions are always saved to the database.
# Set these to also send an email notification via Resend (https://resend.com) — optional.
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=
LEAD_NOTIFICATION_FROM="Marchetti Stone <onboarding@resend.dev>"

# Portal login (single demo credential). Defaults shown on the login page if unset.
PORTAL_EMAIL=client@marchettistone.com
PORTAL_PASSWORD=Whitfield#2026

# Secret used to sign portal session cookies. Set a real random value in
# production — every server instance must share the same secret.
AUTH_SECRET=

# Stripe test-mode secret key (starts with sk_test_). Get one free at
# https://dashboard.stripe.com/test/apikeys. Without it, the Payments page
# runs in demo mode and shows a notice instead of launching checkout.
STRIPE_SECRET_KEY=
